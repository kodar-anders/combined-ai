# Yarn 4 (Plug'n'Play) — non-zero-install.
# Ignore the cache and generated PnP files; keep releases/sdks/etc. committed.
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.pnp.*

# Dependencies (none under PnP, kept as a safeguard)
/node_modules

# Build & coverage output
/dist
/coverage
/out-tsc
/tmp

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local secrets / env (keep .env.example committed)
.env
.env.*
!.env.example

# Editors / OS cruft
.idea/
.vscode/*
.DS_Store

# Claude Code local (per-user) overrides
.claude/settings.local.json
CLAUDE.local.md
