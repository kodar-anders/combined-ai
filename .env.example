# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Used only by the live integration tests (`yarn test:integration`); the
# library itself never reads env vars — consumers pass the key explicitly.

# Anthropic API key (from https://platform.claude.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key (from https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...
