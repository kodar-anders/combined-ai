{
  "name": "combined-ai",
  "version": "0.1.1",
  "description": "Combine multiple AI providers (Anthropic, OpenAI, Gemini) behind one contract — select one by name, or have several cooperate on a prompt.",
  "license": "MIT",
  "author": "Anders Jansson",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kodar-anders/combined-ai.git"
  },
  "homepage": "https://github.com/kodar-anders/combined-ai#readme",
  "bugs": "https://github.com/kodar-anders/combined-ai/issues",
  "keywords": [
    "ai",
    "llm",
    "anthropic",
    "claude",
    "openai",
    "gpt",
    "gemini",
    "provider",
    "consensus",
    "ensemble"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap --clean --treeshake",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:integration": "RUN_LIVE_TESTS=1 sh -c 'jest ${1:-integration}' --",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepack": "yarn build"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.4.1",
    "@swc/core": "^1.15.41",
    "@swc/jest": "^0.2.39",
    "@types/node": "^24",
    "dotenv": "^17.4.2",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-unicorn": "^65.0.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "prettier": "^3.8.4",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "resolutions": {
    "esbuild": "0.28.1",
    "js-yaml": "4.2.0"
  },
  "packageManager": "yarn@4.16.0",
  "volta": {
    "node": "24.14.0",
    "yarn": "4.16.0"
  }
}
